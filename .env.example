# Environment variables
# Copy to .env and fill in values before running

# Port the backend API server listens on
WORKBENCH_BACKEND_PORT=8000

# Set to true in production to enforce secure (HTTPS-only) session cookies
WORKBENCH_SESSION_COOKIE_SECURE=false

# Comma-separated list of trusted origins for CORS / CSRF protection
WORKBENCH_TRUSTED_ORIGINS=http://localhost:5173

# Secret used to verify incoming webhook payloads
WORKBENCH_WEBHOOK_SECRET=
